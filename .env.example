# OpenAI (required for analysis)
OPENAI_API_KEY=

# Stripe (for payment processing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_SCAN=     # Stripe Price ID for one-time $2 per scan
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature gate: when set, require DATABASE_URL for scans/usage; no localStorage paywall fallback on 503
# RESUME_MATCH_FULL_APP=1

# Database (Neon Postgres)
# DATABASE_URL=postgresql://...?sslmode=require

# Analytics (optional)
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-17988296307
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# Server-side capture (e.g. Stripe webhook); can use same project key as NEXT_PUBLIC_POSTHOG_KEY
# POSTHOG_API_KEY=
# POSTHOG_HOST=   # optional; defaults to NEXT_PUBLIC_POSTHOG_HOST or us.i.posthog.com
